# yaml-language-server: $schema=https://kubernetes-schemas.pages.dev/v1/secret.json
---
# Secrets for the immich-photos-pool backup set.
# This file is a TEMPLATE only. Do not commit the real version.
# Encrypt with: sops --encrypt --in-place secrets.enc.yaml
# Once encrypted, the real file is committed as services/backup/kopia/secrets.enc.yaml.
#
# Flux's `services-backup` Kustomization includes decryption: sops, so the
# encrypted file is applied by Flux transparently.
#
# Two Secrets per PVC:
#   1) kopia-<pvc>            : env-style (KOPIA_PASSWORD, KOPIA_NAS_SFTP_*, KOPIA_B2_*, AWS_*)
#   2) kopia-<pvc>-ssh        : file-style (id_ed25519, known_hosts)
apiVersion: v1
kind: Secret
metadata:
  name: kopia-immich-photos-pool
  namespace: backup
  labels:
    app.kubernetes.io/part-of: backup
    app.kubernetes.io/name: kopia
    backup.zacheryph/pvc: photos-pool
stringData:
  # 32 random bytes (base64). Generate with: head -c 32 /dev/urandom | base64
  KOPIA_PASSWORD: "REPLACE_ME_BASE64_32_BYTES"
  KOPIA_NAS_SFTP_USER: "backup"
  KOPIA_NAS_SFTP_HOST: "REPLACE_ME_WITH_NAS_IP_OR_HOSTNAME"
  KOPIA_NAS_SFTP_PATH: "/volume1/k8s-backups/immich-photos-pool"
  KOPIA_B2_BUCKET: "k8s-backups"
  KOPIA_B2_PATH: "immich-photos-pool"
  KOPIA_B2_ENDPOINT: "s3.us-west-002.backblazeb2.com"
  AWS_ACCESS_KEY_ID: "REPLACE_ME_B2_APPLICATION_KEY_ID"
  AWS_SECRET_ACCESS_KEY: "REPLACE_ME_B2_APPLICATION_KEY"
---
apiVersion: v1
kind: Secret
metadata:
  name: kopia-immich-photos-pool-ssh
  namespace: backup
  labels:
    app.kubernetes.io/part-of: backup
    app.kubernetes.io/name: kopia
    backup.zacheryph/pvc: photos-pool
type: Opaque
stringData:
  # Generate with: ssh-keygen -t ed25519 -N "" -f ~/.ssh/kopia-nas
  # Then: ssh-keyscan -t ed25519 <nas-host> > known_hosts
  id_ed25519: |
    REPLACE_ME_PRIVATE_KEY_CONTENTS
  known_hosts: |
    REPLACE_ME_KNOWN_HOSTS_LINE
